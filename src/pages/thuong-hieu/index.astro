---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Logo from '../../components/Logo.astro';
// Nhận diện AcLab+ — wordmark thuần chữ, font LaTeX (Computer Modern).
---

<BaseLayout title="Nhận diện thương hiệu" description="Logo AcLab+ — wordmark font LaTeX Computer Modern.">
  <Fragment slot="head">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/gh/dreampulse/computer-modern-web-font@master/fonts.css" />
  </Fragment>

  <section class="page-hero">
    <div class="container-narrow">
      <p class="kicker">Brand</p>
      <h1>Logo AcLab+</h1>
      <p class="lead">Logo thuần chữ, đặt bằng font LaTeX <strong>Computer Modern</strong>. Dấu
        <strong>+</strong> (màu marsala) luôn đi liền sau “AcLab”. Đơn giản, học thuật, dùng tốt ở mọi kích cỡ.</p>
    </div>
  </section>

  <section class="section">
    <div class="container-narrow">

      <!-- Logo chính -->
      <div class="block">
        <h2>Logo chính</h2>
        <div class="grid2">
          <div class="stage light"><Logo size={56} tagline={true} /></div>
          <div class="stage dark"><Logo size={56} theme="dark" tagline={true} /></div>
        </div>
      </div>

      <!-- Gọn (không tagline) + kích cỡ nhỏ -->
      <div class="block">
        <h2>Bản gọn &amp; thu nhỏ</h2>
        <div class="stage light row">
          <Logo size={40} />
          <Logo size={28} />
          <Logo size={20} />
        </div>
      </div>

      <!-- Icon vuông -->
      <div class="block">
        <h2>Icon “A+” (favicon / avatar)</h2>
        <p class="desc">Rút gọn còn “A+” cho ô vuông nhỏ — tab trình duyệt, avatar mạng xã hội.</p>
        <div class="stage light row">
          <Logo icon={true} size={84} />
          <Logo icon={true} size={56} />
          <Logo icon={true} size={36} theme="dark" />
        </div>
      </div>

      <!-- Sub-logo International -->
      <div class="block">
        <h2>Sub-logo — AcLab+ International</h2>
        <p class="desc">Thêm chữ <em>International</em> (in nghiêng, cùng font LaTeX) cho hoạt động đối ngoại quốc tế.</p>
        <div class="grid2">
          <div class="stage light"><Logo size={48} intl={true} tagline={true} /></div>
          <div class="stage dark"><Logo size={48} intl={true} theme="dark" tagline={true} /></div>
        </div>
      </div>

      <!-- Màu -->
      <div class="block">
        <h2>Bảng màu</h2>
        <div class="palette">
          <div class="color"><span style="background:#0F2747"></span><b>Navy</b><code>#0F2747</code></div>
          <div class="color"><span style="background:#8A2B2B"></span><b>Marsala</b><code>#8A2B2B</code></div>
          <div class="color"><span style="background:#FFD47A"></span><b>Gold</b><code>#FFD47A</code></div>
          <div class="color"><span style="background:#FBF8F1;border:1px solid #ddd"></span><b>Cream</b><code>#FBF8F1</code></div>
        </div>
      </div>

    </div>
  </section>

  <style>
    .page-hero { padding: 4rem 0 2rem; background: linear-gradient(180deg, var(--bg) 0%, var(--surface-2) 100%); border-bottom: 1px solid var(--border); }
    .page-hero h1 { margin: .6rem 0 1rem; }
    .block { padding: 2.2rem 0; border-bottom: 1px solid var(--border); }
    .block h2 { margin: 0 0 1rem; }
    .desc { color: var(--muted); max-width: 56ch; margin: -.4rem 0 1.2rem; }
    .grid2 { display: grid; grid-template-columns: 1fr 1fr; gap: 1.2rem; }
    @media (max-width: 700px){ .grid2 { grid-template-columns: 1fr; } }
    .stage {
      border-radius: var(--radius-lg); padding: 2.6rem 2rem;
      display: flex; align-items: center; justify-content: center; gap: 2.5rem; flex-wrap: wrap;
      min-height: 120px;
    }
    .stage.row { justify-content: flex-start; }
    .stage.light { background: #fff; border: 1px solid var(--border); }
    .stage.dark { background: #0F2747; }
    .palette { display: flex; flex-wrap: wrap; gap: 1.2rem; }
    .color { display: flex; flex-direction: column; gap: .3rem; font-family: var(--font-sans); font-size: .85rem; }
    .color span { width: 88px; height: 60px; border-radius: 10px; display: block; }
    .color code { color: var(--muted); }
  </style>
</BaseLayout>
