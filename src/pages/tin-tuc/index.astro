---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('posts', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const fmt = (d: Date) =>
  d.toLocaleDateString('vi-VN', { day: '2-digit', month: '2-digit', year: 'numeric' });
---

<BaseLayout title="Tin tức" description="Cập nhật mới nhất từ AcLab+: thông báo, call for papers, seminar và các hoạt động học thuật.">

  <section class="page-hero">
    <div class="container-narrow">
      <p class="kicker">News</p>
      <h1>Tin tức</h1>
      <p class="lead">Thông báo, call for papers, lịch seminar và các hoạt động học thuật của phòng thí nghiệm.</p>
    </div>
  </section>

  <section class="section">
    <div class="container-narrow">
      <ul class="post-list">
        {posts.map(post => (
          <li class="post-item">
            <time datetime={post.data.date.toISOString()}>{fmt(post.data.date)}</time>
            <div>
              <h2><a href={`/tin-tuc/${post.id}/`}>{post.data.title}</a></h2>
              {post.data.description && <p>{post.data.description}</p>}
              <div class="meta">
                {post.data.author && <span class="by">— {post.data.author}</span>}
                {post.data.tags.length > 0 && (
                  <span class="tag-row">
                    {post.data.tags.slice(0, 3).map((t: string) => <span class="tag">{t}</span>)}
                  </span>
                )}
              </div>
            </div>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <style>
    .page-hero { padding: 4rem 0 2rem; background: linear-gradient(180deg, var(--bg) 0%, var(--surface-2) 100%); border-bottom: 1px solid var(--border); }
    .page-hero h1 { margin: .6rem 0 1rem; }
    .post-list { list-style: none; padding: 0; margin: 0; }
    .post-item {
      display: grid; grid-template-columns: 110px 1fr; gap: 1.6rem;
      padding: 2rem 0; border-bottom: 1px solid var(--border);
    }
    @media (max-width: 600px) {
      .post-item { grid-template-columns: 1fr; gap: .5rem; }
    }
    .post-item time {
      font-family: var(--font-sans); font-size: .85rem;
      color: var(--accent-2); letter-spacing: .03em;
      padding-top: .4rem;
    }
    .post-item h2 {
      font-size: 1.35rem; margin: 0 0 .5rem; line-height: 1.3;
    }
    .post-item h2 a { color: var(--text); text-decoration: none; }
    .post-item h2 a:hover { color: var(--accent-2); }
    .post-item p { color: var(--muted); margin: 0 0 .8rem; line-height: 1.7; }
    .meta {
      display: flex; flex-wrap: wrap; gap: .8rem; align-items: center;
      font-family: var(--font-sans); font-size: .85rem; color: var(--muted);
    }
    .tag-row { display: inline-flex; gap: .4rem; flex-wrap: wrap; }
  </style>
</BaseLayout>
