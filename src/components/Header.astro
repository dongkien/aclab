---
const { pathname } = Astro.url;
// Ghép base (vd '/aclab/') vào đường dẫn gốc để link đúng khi deploy ở thư mục con
const withBase = (href: string) => import.meta.env.BASE_URL.replace(/\/$/, '') + href;
const nav = [
  { href: '/gioi-thieu/',       label: 'Giới thiệu' },
  { href: '/hoat-dong/',        label: 'Hoạt động' },
  { href: '/thanh-vien/',       label: 'Thành viên' },
  { href: '/san-pham/',         label: 'Sản phẩm' },
  { href: '/tin-tuc/',          label: 'Tin tức' },
  { href: '/lien-he/',          label: 'Liên hệ' },
];
const isActive = (href: string) => {
  const full = withBase(href);
  return pathname === full || (href !== '/' && pathname.startsWith(full));
};
---

<header class="site-header">
  <div class="container header-row">
    <a class="brand" href={withBase('/')} aria-label="Trang chủ AcLab+">
      <span class="brand-mark" aria-hidden="true">A<span class="brand-plus">+</span></span>
      <span class="brand-text">
        <span class="brand-name">AcLab<span class="brand-plus-text">+</span></span>
        <span class="brand-tag">Academic Laboratory</span>
      </span>
    </a>

    <nav class="site-nav" aria-label="Điều hướng chính">
      <ul>
        {nav.map(item => (
          <li>
            <a href={withBase(item.href)} class={isActive(item.href) ? 'active' : ''}>{item.label}</a>
          </li>
        ))}
      </ul>
    </nav>

    <a href={withBase('/tuyen-thanh-vien/')} class="btn btn-primary header-cta">Tham gia</a>

    <button class="nav-toggle" aria-label="Mở menu" aria-expanded="false" id="navToggle">
      <span></span><span></span><span></span>
    </button>
  </div>

  <nav class="mobile-nav" id="mobileNav" aria-label="Điều hướng di động">
    <ul>
      {nav.map(item => (
        <li><a href={withBase(item.href)} class={isActive(item.href) ? 'active' : ''}>{item.label}</a></li>
      ))}
      <li><a href={withBase('/tuyen-thanh-vien/')} class="cta">Tham gia cùng chúng tôi</a></li>
    </ul>
  </nav>
</header>

<script>
  const btn = document.getElementById('navToggle');
  const nav = document.getElementById('mobileNav');
  btn?.addEventListener('click', () => {
    const open = nav?.classList.toggle('open');
    btn.setAttribute('aria-expanded', String(open));
    btn.classList.toggle('open', open);
  });
</script>

<style>
  .site-header {
    position: sticky; top: 0; z-index: 30;
    background: color-mix(in srgb, var(--bg) 92%, transparent);
    backdrop-filter: saturate(160%) blur(8px);
    border-bottom: 1px solid var(--border);
  }
  .header-row {
    display: flex; align-items: center; gap: 1.5rem;
    padding: .9rem 1.4rem;
  }
  .brand {
    display: inline-flex; align-items: center; gap: .65rem;
    color: var(--text); text-decoration: none;
  }
  .brand:hover { color: var(--text); }
  .brand-mark {
    width: 38px; height: 38px;
    display: inline-flex; align-items: center; justify-content: center;
    background: var(--accent); color: #fff;
    font-family: var(--font-sans); font-weight: 700; font-size: 1.15rem;
    border-radius: 8px; letter-spacing: -.02em;
  }
  .brand-plus { color: #ffd47a; margin-left: 1px; }
  .brand-text { display: flex; flex-direction: column; line-height: 1.1; }
  .brand-name {
    font-family: var(--font-sans); font-weight: 700;
    font-size: 1.15rem; letter-spacing: -.01em;
  }
  .brand-plus-text { color: var(--accent-2); }
  .brand-tag {
    font-family: var(--font-sans); font-size: .68rem;
    letter-spacing: .14em; text-transform: uppercase;
    color: var(--muted); margin-top: 2px;
  }
  .site-nav { flex: 1; }
  .site-nav ul {
    list-style: none; margin: 0; padding: 0;
    display: flex; justify-content: center; gap: .2rem;
  }
  .site-nav a {
    font-family: var(--font-sans); font-weight: 500;
    font-size: .94rem; color: var(--text);
    padding: .55rem .9rem; border-radius: var(--radius);
    text-decoration: none;
    transition: background var(--t), color var(--t);
  }
  .site-nav a:hover { background: var(--surface-2); color: var(--accent); }
  .site-nav a.active { color: var(--accent); position: relative; }
  .site-nav a.active::after {
    content: ''; position: absolute; left: .9rem; right: .9rem; bottom: 0;
    height: 2px; background: var(--accent-2); border-radius: 1px;
  }
  .header-cta { padding: .55rem 1.1rem; font-size: .9rem; }
  .nav-toggle {
    display: none;
    background: none; border: none; cursor: pointer;
    width: 40px; height: 40px; padding: 8px;
    flex-direction: column; justify-content: space-around;
  }
  .nav-toggle span {
    display: block; height: 2px; background: var(--text);
    border-radius: 1px; transition: transform var(--t), opacity var(--t);
  }
  .nav-toggle.open span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
  .nav-toggle.open span:nth-child(2) { opacity: 0; }
  .nav-toggle.open span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

  .mobile-nav {
    display: none;
    border-top: 1px solid var(--border);
    background: var(--surface);
  }
  .mobile-nav.open { display: block; }
  .mobile-nav ul {
    list-style: none; padding: .8rem 1.4rem 1.2rem; margin: 0;
  }
  .mobile-nav a {
    display: block; padding: .8rem .4rem;
    font-family: var(--font-sans); color: var(--text);
    border-bottom: 1px solid var(--border-soft);
    text-decoration: none;
  }
  .mobile-nav a.active { color: var(--accent); font-weight: 600; }
  .mobile-nav a.cta { color: var(--accent-2); font-weight: 600; }

  @media (max-width: 900px) {
    .site-nav, .header-cta { display: none; }
    .nav-toggle { display: flex; }
  }
</style>
