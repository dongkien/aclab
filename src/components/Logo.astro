---
// Logo AcLab+ — WORDMARK thuần chữ, font LaTeX (Computer Modern).
// Không vẽ icon đặt-tọa-độ. Chỉ dùng chữ + canh giữa bằng flexbox → không thể lệch.
// Trang dùng phải nạp font 'Computer Modern Serif'
// (<head>: https://cdn.jsdelivr.net/gh/dreampulse/computer-modern-web-font@master/fonts.css)
interface Props {
  theme?: 'light' | 'dark';
  size?: number;        // cỡ chữ "AcLab+" (px); với icon là cạnh ô vuông (px)
  tagline?: boolean;
  intl?: boolean;
  icon?: boolean;       // ô vuông "A+" (favicon / avatar)
}
const { theme = 'light', size = 40, tagline = false, intl = false, icon = false } = Astro.props;
const ink  = theme === 'dark' ? '#FFFFFF' : '#0F2747';
const plus = theme === 'dark' ? '#FFD47A' : '#8A2B2B';
const tagc = theme === 'dark' ? '#AEB6C8' : '#7A8499';
const tileBg = theme === 'dark' ? '#FFFFFF' : '#0F2747';
const tileInk = theme === 'dark' ? '#0F2747' : '#FFFFFF';
const tilePlus = theme === 'dark' ? '#8A2B2B' : '#FFD47A';
---

{icon ? (
  <span class="aclab-icon" style={`--s:${size}px; background:${tileBg}; color:${tileInk}`}>
    A<span class="ic-plus" style={`color:${tilePlus}`}>+</span>
  </span>
) : (
  <span class="aclab-logo" style={`--s:${size}px`}>
    <span class="name" style={`color:${ink}`}>AcLab<span class="plus" style={`color:${plus}`}>+</span>{intl && <span class="intl"> International</span>}</span>
    {tagline && <span class="tag" style={`color:${tagc}`}>{intl ? 'International Academic Laboratory' : 'Academic Laboratory'}</span>}
  </span>
)}

<style>
  .aclab-logo { display: inline-flex; flex-direction: column; line-height: 1.04; }
  .aclab-logo .name {
    font-family: 'Computer Modern Serif', Georgia, serif;
    font-weight: 700; font-size: var(--s); letter-spacing: .003em;
  }
  .aclab-logo .plus { font-weight: 700; margin-left: .03em; }
  .aclab-logo .intl { font-weight: 400; font-style: italic; font-size: .6em; letter-spacing: .01em; }
  .aclab-logo .tag {
    font-family: 'Be Vietnam Pro', system-ui, sans-serif;
    font-weight: 500; font-size: calc(var(--s) * .25);
    letter-spacing: .2em; text-transform: uppercase; margin-top: .55em;
  }
  /* Ô vuông "A+" — canh giữa bằng flexbox, không tọa độ tay */
  .aclab-icon {
    font-family: 'Computer Modern Serif', Georgia, serif;
    font-weight: 700; font-size: calc(var(--s) * .56);
    width: var(--s); height: var(--s);
    border-radius: calc(var(--s) * .2);
    display: inline-flex; align-items: center; justify-content: center;
    padding-right: .04em; /* bù quang học do dấu + lệch phải */
  }
  .aclab-icon .ic-plus { margin-left: .02em; }
</style>
