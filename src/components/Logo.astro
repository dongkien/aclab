---
// Logo AcLab+ — biểu tượng chính là "A+" (nghĩa: điểm A+, xuất sắc).
// Dùng ĐÚNG font + kiểu của logo header góc trên trái: Be Vietnam Pro, ô vuông navy,
// A trắng + dấu + vàng. Canh giữa bằng flexbox (giống header → render chuẩn).
interface Props {
  theme?: 'light' | 'dark';
  size?: number;        // cạnh ô "A+" (px)
  iconOnly?: boolean;   // chỉ biểu tượng A+
  intl?: boolean;       // wordmark "AcLab+ Int'"
}
const { theme = 'light', size = 48, iconOnly = false, intl = false } = Astro.props;
const tileBg  = theme === 'dark' ? '#FFFFFF' : '#0F2747';
const tileA   = theme === 'dark' ? '#0F2747' : '#FFFFFF';
const tileP   = '#FFD47A';                                   // dấu + trên ô: vàng gold
const wordInk = theme === 'dark' ? '#FFFFFF' : '#0F2747';
const wordP   = theme === 'dark' ? '#FFD47A' : '#8A2B2B';    // dấu + trong chữ: marsala (nền tối → vàng)
const intInk  = theme === 'dark' ? '#AEB6C8' : '#8A2B2B';
---

<span class={`aclab ${iconOnly ? 'only' : ''}`} style={`--s:${size}px`}>
  <span class="badge" style={`background:${tileBg}; color:${tileA}`}>
    A<span class="bp" style={`color:${tileP}`}>+</span>
  </span>
  {!iconOnly && (
    <span class="wm" style={`color:${wordInk}`}>AcLab<span class="wp" style={`color:${wordP}`}>+</span>{intl && <span class="int" style={`color:${intInk}`}> Int’</span>}</span>
  )}
</span>

<style>
  .aclab { display: inline-flex; align-items: center; gap: calc(var(--s) * .26); line-height: 1; }
  .aclab.only { gap: 0; }
  .badge {
    width: var(--s); height: var(--s); flex: none;
    border-radius: calc(var(--s) * .2);
    display: inline-flex; align-items: center; justify-content: center;
    font-family: var(--font-sans); font-weight: 700;
    font-size: calc(var(--s) * .5); letter-spacing: -.03em;
    padding-right: calc(var(--s) * .03);
  }
  .badge .bp { margin-left: .03em; }
  .wm {
    font-family: var(--font-sans); font-weight: 700;
    font-size: calc(var(--s) * .66); letter-spacing: -.01em;
  }
  .wm .int { font-weight: 600; font-size: .68em; letter-spacing: 0; }
</style>
